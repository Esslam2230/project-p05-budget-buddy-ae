<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    {% endblock %}
    {% block javascripts %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    {% endblock %}
</head>
<body>
<nav>

    <ul>
        <li><a href="{{ path('app_home') }}">Home</a></li>
        <li><a href="{{ path('app_index') }}">Personen</a></li>
        <li><a href="{{ path('app_category') }}">Categorie</a></li>
        <li><a href="{{ path('app_contact') }}">Contact</a></li>
    </ul>
    <div>
        <img src="{{ asset('img/logo.png') }}" alt="logo">
    </div>
</nav>

{% block body %}{% endblock %}
{# ✅ Footer toegevoegd #}
<footer class="footer">
    <div class="footer-container">
        <div class="footer-about">
            <h4>Budget Buddy</h4>
            <p>Een slimme manier om je financiën te beheren. Houd overzicht, plan vooruit en bespaar gemakkelijk.</p>
        </div>

        <div class="footer-links">
            <h4>Snelle links</h4>
            <ul>
                <li><a href="{{ path('app_index') }}">Gebruikers</a></li>
                <li><a href="{{ path('app_category') }}">Categorieën</a></li>
                <li><a href="{{ path('app_contact') }}">Contact</a></li>
            </ul>
        </div>

        <div class="footer-contact">
            <h4>Contact</h4>
            <p>Email: <a href="mailto:info@budgetbuddy.nl">info@budgetbuddy.nl</a></p>
            <p>Tel: <a href="tel:+31000000000">+31 00 000 0000</a></p>
        </div>
    </div>

    <div class="footer-bottom">
        <p>&copy; {{ "now"|date("Y") }} Budget Buddy. Alle rechten voorbehouden.</p>
        <small>Gemaakt met ❤️ in Symfony</small>
    </div>
</footer>

</body>
</html>
