{% extends 'base.html.twig' %}

{% block title %}Categorie toevoegen{% endblock %}

{% block body %}
    <section class="category-form-section">
        <h2 class="page-title">Categorie {{ category is defined ? 'bewerken' : 'toevoegen' }}</h2>

        {{ form_start(form) }}
        {{ form_widget(form) }}
        <button class="btn btn-blue">Opslaan</button>
        {{ form_end(form) }}

        <div class="centered mt-4">
            <a href="{{ path('app_category') }}" class="btn btn-grey">← Terug naar overzicht</a>
        </div>
    </section>
{% endblock %}
