{% extends 'base.html.twig' %}

{% block title %}Categorie bewerken{% endblock %}

{% block body %}
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">

                <div class="card shadow-sm" style="border-color: var(--color-border);">
                    <div class="card-header text-white"
                         style="background-color: var(--color-nav-bg); border-bottom: 3px solid var(--color-border);">
                        <h4 class="mb-0">Categorie bewerken</h4>
                    </div>

                    <div class="card-body">
                        {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}

                        <div class="mb-3">
                            {{ form_label(form.name, 'Naam', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.name, {'attr': {'class': 'form-control', 'style': 'border-color: var(--color-border);'}}) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.incomeExpense, 'Type', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.incomeExpense, {'attr': {'class': 'form-select', 'style': 'border-color: var(--color-border);'}}) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.description, 'Beschrijving', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.description, {
                                'attr': {
                                    'class': 'form-control',
                                    'rows': 3,
                                    'style': 'border-color: var(--color-border);'
                                }
                            }) }}
                        </div>

                        <button type="submit"
                                class="btn w-100"
                                style="background-color: var(--color-nav-bg);
                                   color: var(--color-accent);
                                   border: 2px solid var(--color-border);">
                            Opslaan
                        </button>

                        {{ form_end(form) }}
                    </div>
                </div>

                <div class="text-center mt-3">
                    <a href="{{ path('app_category') }}"
                       class="btn"
                       style="border: 2px solid var(--color-border);
                          color: var(--color-nav-bg);
                          background-color: var(--color-accent);">
                        ← Terug naar overzicht
                    </a>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
